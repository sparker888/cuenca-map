# Cuenca Maps environment.
# Copy to .env and fill in. .env is git-ignored — never commit real secrets.

# PocketBase backend (fly.io). Used by the build-time loaders (server-side).
POCKETBASE_URL=https://cuenca-map-production.fly.dev
# Same URL exposed to the browser for live specials + waitlist (must be PUBLIC_).
PUBLIC_POCKETBASE_URL=https://cuenca-map-production.fly.dev
# Public site URL.
PUBLIC_APP_URL=https://cuencamap.com

# Admin (superuser) credentials — LOCAL ONLY. Used by pocketbase/scripts/* for
# setup/seed/migration. NEVER set these in Netlify or any client/build env.
POCKETBASE_ADMIN_EMAIL=you@example.com
POCKETBASE_ADMIN_PASSWORD=change-me
