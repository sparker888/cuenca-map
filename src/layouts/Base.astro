---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = "An interactive guide to the places expats love in Cuenca, Ecuador — with long-form reviews of the restaurants worth your time.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400..600;1,6..72,400..500&family=Hanken+Grotesk:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-paper text-ink">
    <slot />
    <script>
      import "../i18n/client";
    </script>
  </body>
</html>
