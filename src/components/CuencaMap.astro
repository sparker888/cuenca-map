---
import Illustration from "./Illustration.astro";
import type { Place, CategoryMeta } from "../data/places";

interface Props {
  places: Place[];
  categoryMeta: CategoryMeta;
}
const { places, categoryMeta } = Astro.props;

// Only surface categories that actually have listings.
const present = new Set(places.map((p) => p.category));
const presentMeta = Object.fromEntries(
  Object.entries(categoryMeta).filter(([key]) => present.has(key as any))
) as typeof categoryMeta;

const categories = Object.entries(presentMeta).map(([key, meta]) => ({ key, ...meta }));
const premium = places.filter((p) => p.tier === "premium" && p.illo);

// Serialized for the client script (build-time data; map stays static).
const cmData = JSON.stringify({ places, categoryMeta: presentMeta }).replace(/</g, "\\u003c");
---

<div class="relative overflow-hidden rounded-2xl border border-indigo-700/60 shadow-[0_28px_70px_-30px_rgba(0,0,0,.7)]" style="background:#0c1626">
  <!-- Filter row (labels filled + translated by the client script) -->
  <div
    class="chip-row pointer-events-auto absolute inset-x-0 top-0 z-[610] flex items-center gap-2 overflow-x-auto px-4 py-3.5"
    style="background:linear-gradient(180deg,rgba(12,22,38,.96),rgba(12,22,38,0))"
    id="cm-chips"
  >
    <button data-filter="all" class="cm-chip flex-none whitespace-nowrap rounded-full bg-gold px-3.5 py-1.5 text-[13px] font-semibold text-[#3a2a08]">All</button>
    {categories.map((c) => (
      <button data-filter={c.key} class="cm-chip flex-none whitespace-nowrap rounded-full border border-gold/45 bg-[#0e1a2e]/55 px-3.5 py-1.5 text-[13px] text-[#dbe4f0] backdrop-blur-md"></button>
    ))}
  </div>

  <div id="cuenca-leaflet" class="h-[68vh] min-h-[460px] w-full" role="application" aria-label="Map of Cuenca"></div>

  <aside
    id="cm-panel"
    class="absolute left-4 top-[64px] z-[620] hidden w-[358px] max-w-[calc(100%-2rem)] overflow-y-auto rounded-2xl border border-white/10 p-5 shadow-2xl"
    style="max-height:calc(100% - 84px);background:#182742;color:#f4efe2"
    aria-live="polite"
  ></aside>

  <div
    id="cm-legend"
    class="absolute bottom-4 left-4 z-[600] hidden max-w-[300px] flex-wrap gap-x-3.5 gap-y-1 rounded-xl border border-white/10 px-3.5 py-2.5 text-[12px] backdrop-blur md:flex"
    style="background:rgba(12,22,38,.86);color:#9fb0c6"
  ></div>

  <!-- Pre-rendered illustrations for the client script to drop into the panel -->
  <div id="cm-illos" hidden>
    {premium.map((p) => (
      <div data-illo-for={p.id}><Illustration name={p.illo!} /></div>
    ))}
  </div>
  <span hidden id="cm-contact" data-email="hello@gravitaldigital.com"></span>
  <script type="application/json" id="cm-data" set:html={cmData}></script>
</div>

<script>
  import L from "leaflet";
  import "leaflet/dist/leaflet.css";
  import { UI, getLang } from "../i18n/ui";
  import { fetchActiveSpecials, specialDateLabel } from "../lib/specials";
  import type { Place, Category } from "../data/places";

  // Build-time data, embedded as JSON by the component above.
  const cmData = JSON.parse(document.getElementById("cm-data")!.textContent!) as {
    places: Place[];
    categoryMeta: Record<Category, { label: string; color: string }>;
  };
  const places = cmData.places;
  const categoryMeta = cmData.categoryMeta;

  const t = (key: string) => UI[getLang()]?.[key] ?? UI.en[key] ?? key;
  const catLabel = (cat: string) => t("cat_" + cat);
  const contact = document.getElementById("cm-contact")!.dataset.email || "";
  const esc = (s = "") => s.replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c] as string));
  const dirUrl = (p: Place) => `https://www.google.com/maps/dir/?api=1&destination=${p.lat},${p.lng}`;
  const illoFor = (id: string) => document.querySelector(`#cm-illos [data-illo-for="${id}"]`)?.innerHTML || "";

  const BOUNDS = L.latLngBounds([-2.96, -79.07], [-2.85, -78.95]);
  const map = L.map("cuenca-leaflet", { zoomControl: false, minZoom: 12, maxZoom: 19, maxBounds: BOUNDS, maxBoundsViscosity: 1 }).setView([-2.9015, -79.004], 14);
  L.control.zoom({ position: "topright" }).addTo(map);
  // No-label basemap so our recolored rivers/roads + custom CUENCA label read clearly.
  L.tileLayer("https://{s}.basemaps.cartocdn.com/dark_nolabels/{z}/{x}/{y}{r}.png", {
    attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/attributions">CARTO</a>',
    maxZoom: 19, noWrap: true, bounds: BOUNDS,
  }).addTo(map);

  // --- CUENCA label, lifted north toward Av. de las Américas, clear of the pins ---
  L.marker([-2.889, -79.004], {
    interactive: false,
    keyboard: false,
    icon: L.divIcon({ className: "cm-citylabel", html: "<span>CUENCA</span>", iconSize: [180, 40], iconAnchor: [90, 20] }),
  }).addTo(map);

  function makeIcon(p: Place) {
    const color = categoryMeta[p.category].color;
    const prem = p.tier === "premium";
    return L.divIcon({
      className: prem ? "cm-pin cm-pin--premium" : "cm-pin",
      html: `<span class="cm-pin__dot" style="background:${color}">${prem ? '<span class="cm-pin__star">★</span>' : ""}</span>`,
      iconSize: prem ? [32, 32] : [22, 22],
      iconAnchor: prem ? [16, 16] : [11, 11],
    });
  }
  const markers = new Map<string, L.Marker>();
  places.forEach((p) => {
    const m = L.marker([p.lat, p.lng], { icon: makeIcon(p), title: p.name });
    m.on("click", () => select(p.id));
    m.addTo(map);
    markers.set(p.id, m);
  });

  // ---- Filters ----
  let active = "all";
  const chips = [...document.querySelectorAll<HTMLButtonElement>(".cm-chip")];
  const BASE = "cm-chip flex-none whitespace-nowrap rounded-full px-3.5 py-1.5 text-[13px] backdrop-blur-md transition";
  const dot = (f: string) => (f === "all" ? "" : `<span class="mr-1.5 inline-block h-2 w-2 rounded-full align-middle" style="background:${categoryMeta[f as Category].color}"></span>`);
  function paintChips() {
    chips.forEach((c) => {
      const f = c.dataset.filter!, on = f === active;
      c.className = on
        ? `${BASE} font-semibold shadow-sm ${f === "all" ? "bg-gold text-[#3a2a08]" : "bg-paper text-indigo"}`
        : `${BASE} border border-gold/45 bg-[#0e1a2e]/55 text-[#dbe4f0] hover:border-gold/70 hover:bg-[#16243b]/75 hover:text-white`;
      c.innerHTML = `${dot(f)}${f === "all" ? t("filter_all") : catLabel(f)}`;
    });
  }
  chips.forEach((chip) =>
    chip.addEventListener("click", () => {
      active = chip.dataset.filter!;
      paintChips();
      places.forEach((p) => {
        const show = active === "all" || p.category === active;
        const m = markers.get(p.id)!;
        if (show) m.addTo(map); else m.remove();
      });
    })
  );

  // ---- Legend ----
  const legendEl = document.getElementById("cm-legend") as HTMLElement;
  function renderLegend() {
    const cats = Object.keys(categoryMeta).map((k) =>
      `<span class="inline-flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-full" style="background:${categoryMeta[k as Category].color}"></span>${catLabel(k).split(" ")[0]}</span>`
    ).join("");
    legendEl.innerHTML = cats +
      `<span class="inline-flex items-center gap-1.5 font-semibold text-gold-soft"><span class="grid h-2.5 w-2.5 place-items-center rounded-full text-[7px] text-[#16243b]" style="background:#d6a53c">★</span>${t("legend_reviewed")}</span>`;
  }

  // ---- Detail panel ----
  const panel = document.getElementById("cm-panel") as HTMLElement;
  let lastId: string | null = null;
  function ratingPill(p: Place) {
    if (!p.rating) return "";
    const fav = p.ratingCount && p.ratingCount > 1000 ? " · " + t("fav") : "";
    return `<span class="mt-3 inline-flex items-center gap-1.5 rounded-full border px-3 py-1 text-[13px] font-semibold" style="border-color:rgba(214,165,60,.55);background:rgba(214,165,60,.14);color:#e7c982">★ ${p.rating}${fav}</span>`;
  }
  function select(id: string, fly = true) {
    const p = places.find((x) => x.id === id);
    if (!p) return;
    lastId = id;
    const c = categoryMeta[p.category];
    const featured = p.tier === "premium";
    const reviewBtn = p.reviewSlug
      ? `<a href="/reviews/${p.reviewSlug}" class="mt-4 flex items-center justify-between rounded-xl border border-gold/40 bg-gold/10 px-4 py-3 text-sm font-semibold text-gold-soft transition hover:bg-gold/20">★ ${t("panel_review")} <span>→</span></a>`
      : `<a href="/list-your-business" class="mt-4 block border-t border-white/10 pt-3.5 text-[13px] text-[#7fb0e6]">${t("panel_claim")}</a>`;
    panel.innerHTML = `
      <button data-close class="absolute right-3.5 top-3 text-xl leading-none text-white/60 hover:text-white">×</button>
      ${featured ? `<div class="mb-4 -mx-1 overflow-hidden rounded-xl">${illoFor(p.id)}</div>` : ""}
      <span class="eyebrow text-[11px] font-bold uppercase" style="color:${featured ? "#e7c982" : c.color}">${catLabel(p.category)}</span>
      <h3 class="mt-1.5 pr-6 font-display text-2xl font-semibold leading-tight">${esc(p.name)}</h3>
      ${ratingPill(p)}
      ${p.tagline ? `<p class="mt-3 font-display text-[17px] italic text-gold-soft">${esc(p.tagline)}</p>` : ""}
      ${p.description ? `<p class="mt-2 text-sm leading-relaxed text-[#dfe6f0]">${esc(p.description)}</p>` : p.address ? `<p class="mt-3 text-sm text-[#9fb0c6]">${esc(p.address)}</p>` : ""}
      ${p.hours ? `<div class="mt-4"><p class="eyebrow text-[10px] font-bold uppercase text-[#7e8ba0]">${t("panel_hours")}</p><p class="mt-1 text-sm">${esc(p.hours[0])}</p></div>` : ""}
      <div class="mt-4 flex items-center gap-4">
        <a href="${dirUrl(p)}" target="_blank" rel="noopener" class="rounded-lg bg-gold px-4 py-2.5 text-[13px] font-bold text-[#3a2a08] transition hover:bg-gold-soft">${t("panel_directions")}</a>
        ${p.website ? `<a href="${esc(p.website)}" target="_blank" rel="noopener" class="text-[13px] font-semibold text-[#f4efe2] opacity-90 hover:opacity-100">${t("panel_website")}</a>` : ""}
      </div>
      ${reviewBtn}`;
    panel.classList.remove("hidden");
    panel.scrollTop = 0;
    panel.querySelector("[data-close]")?.addEventListener("click", () => panel.classList.add("hidden"));
    if (fly) map.flyTo([p.lat, p.lng], Math.max(map.getZoom(), 16), { duration: 0.6 });

    // Live specials — client-fetched, so they appear without a site rebuild.
    const specialsHost = document.createElement("div");
    panel.appendChild(specialsHost);
    fetchActiveSpecials(p.id).then((specials) => {
      if (lastId !== id || !specials.length) return;
      specialsHost.innerHTML = `<div class="mt-5 border-t border-white/10 pt-4">
        <p class="eyebrow text-[10px] font-bold uppercase text-gold-soft">${t("panel_specials")}</p>
        <ul class="mt-2 space-y-2">${specials.map((s) => `
          <li class="rounded-lg border border-gold/25 bg-gold/5 px-3 py-2">
            <p class="text-[13px] font-semibold text-[#f4efe2]">${esc(s.title)}</p>
            ${s.description ? `<p class="mt-0.5 text-[12.5px] leading-snug text-[#cdd6e3]">${esc(s.description)}</p>` : ""}
            ${specialDateLabel(s) ? `<p class="mt-1 text-[11px] text-gold-soft">${esc(specialDateLabel(s))}</p>` : ""}
          </li>`).join("")}</ul></div>`;
    });
  }
  document.addEventListener("keydown", (e) => { if (e.key === "Escape") panel.classList.add("hidden"); });

  // ---- i18n: re-render on toggle ----
  window.addEventListener("langchange", () => {
    paintChips();
    renderLegend();
    if (lastId && !panel.classList.contains("hidden")) select(lastId, false);
  });
  paintChips();
  renderLegend();
</script>
