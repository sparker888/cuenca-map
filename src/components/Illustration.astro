---

<svg
  viewBox="0 0 400 300"
  preserveAspectRatio="xMidYMid slice"
  class={`h-full w-full ${className}`}
  role="img"
  aria-label={`Illustration: ${name}`}
>
  <rect width="400" height="300" fill={bg} />
  <Fragment set:html={ART[name]} />
</svg>
