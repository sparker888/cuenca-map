---
// Site navigation. `active` highlights the current section.
// Desktop: links sit inline. Mobile: links collapse behind a hamburger so the
// logo + language toggle never get clipped on narrow viewports.
interface Props {
  active?: "map" | "reviews" | "about" | "list";
}
const { active } = Astro.props;
const link = "rounded-full px-3.5 py-2 transition";
const on = "text-indigo";
const off = "text-slate hover:bg-marble hover:text-ink";
// Stacked variant for the mobile dropdown panel.
const mlink = "block rounded-xl px-4 py-3 text-base font-medium transition";
const mon = "bg-marble text-indigo";
const moff = "text-slate hover:bg-marble hover:text-ink";
---

<header class="sticky top-0 z-[700] border-b border-line bg-paper/90 backdrop-blur-md">
  <div class="mx-auto flex max-w-[1240px] items-center justify-between gap-6 px-6 py-3.5">
    <a href="/" class="flex items-center gap-3">
      <span class="flex items-center gap-2 font-display text-2xl font-semibold leading-none text-indigo">
        <svg viewBox="0 0 24 32" class="w-auto shrink-0" style="height:0.85em" role="img" aria-label="Cuenca Maps">
          <defs>
            <linearGradient id="navPin" gradientUnits="userSpaceOnUse" x1="12" y1="2" x2="12" y2="30">
              <stop offset="0%" stop-color="#c0533b"/><stop offset="60%" stop-color="#c0533b"/>
              <stop offset="60%" stop-color="#d6a53c"/><stop offset="100%" stop-color="#d6a53c"/>
            </linearGradient>
          </defs>
          <path d="M12 2C6.48 2 2 6.48 2 12c0 7.5 10 18 10 18s10-10.5 10-18C22 6.48 17.52 2 12 2z" fill="url(#navPin)" stroke="#14233b" stroke-width="1.3"/>
          <circle cx="12" cy="12" r="3.9" fill="#faf6ee"/>
        </svg>
        <span>Cuenca</span>
      </span>
      <span class="eyebrow hidden text-[10px] font-bold uppercase text-gold sm:inline">Expat Map</span>
    </a>
    <div class="flex items-center gap-0.5 text-sm font-medium">
      <nav class="hidden items-center gap-0.5 whitespace-nowrap sm:flex">
        <a href="/" class={`${link} ${active === "map" ? on : off}`} data-i18n="nav_map">Map</a>
        <a href="/reviews" class={`${link} ${active === "reviews" ? on : off}`} data-i18n="nav_reviews">Reviews</a>
        <a href="/about" class={`${link} ${active === "about" ? on : off}`} data-i18n="nav_about">About</a>
        <a href="/list-your-business" class={`${link} ${active === "list" ? on : off}`} data-i18n="nav_list">List your business</a>
      </nav>
      <button
        type="button"
        onclick="window.toggleLang()"
        aria-label="Toggle language"
        class="ml-1 inline-flex items-center gap-1.5 rounded-full border border-line px-3 py-1.5 text-[12px] font-bold text-slate transition hover:border-cobalt hover:text-cobalt"
      >
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"></circle><path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"></path></svg>
        <span data-lang-label>ES</span>
      </button>
      <button
        type="button"
        data-menu-toggle
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="ml-1 inline-flex h-9 w-9 items-center justify-center rounded-full border border-line text-slate transition hover:border-cobalt hover:text-cobalt sm:hidden"
      >
        <svg data-menu-open width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18"></path></svg>
        <svg data-menu-close class="hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"></path></svg>
      </button>
    </div>
  </div>
  <nav id="mobile-menu" hidden class="border-t border-line px-4 pb-4 pt-2 sm:hidden">
    <a href="/" class={`${mlink} ${active === "map" ? mon : moff}`} data-i18n="nav_map">Map</a>
    <a href="/reviews" class={`${mlink} ${active === "reviews" ? mon : moff}`} data-i18n="nav_reviews">Reviews</a>
    <a href="/about" class={`${mlink} ${active === "about" ? mon : moff}`} data-i18n="nav_about">About</a>
    <a href="/list-your-business" class={`${mlink} ${active === "list" ? mon : moff}`} data-i18n="nav_list">List your business</a>
  </nav>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
  const menu = document.getElementById("mobile-menu");
  const openIcon = toggle?.querySelector<SVGElement>("[data-menu-open]");
  const closeIcon = toggle?.querySelector<SVGElement>("[data-menu-close]");

  function setOpen(open: boolean) {
    if (!toggle || !menu) return;
    menu.hidden = !open;
    toggle.setAttribute("aria-expanded", String(open));
    openIcon?.classList.toggle("hidden", open);
    closeIcon?.classList.toggle("hidden", !open);
  }

  toggle?.addEventListener("click", () => setOpen(menu?.hidden ?? false));
  // Close after navigating or when the layout grows past the mobile breakpoint.
  menu?.querySelectorAll("a").forEach((a) => a.addEventListener("click", () => setOpen(false)));
  window.matchMedia("(min-width: 640px)").addEventListener("change", (e) => {
    if (e.matches) setOpen(false);
  });
</script>
