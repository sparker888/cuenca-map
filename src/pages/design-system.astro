---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import AndesBackdrop from "../components/AndesBackdrop.astro";
import Illustration from "../components/Illustration.astro";
import type { IlloName } from "../data/places";

const neutral = [
  { n: "Paper", hex: "#faf6ee", role: "bg" },
  { n: "Marble", hex: "#f1ece0", role: "surface" },
  { n: "Line", hex: "#e3ddce", role: "border" },
  { n: "Ink", hex: "#1d1b17", role: "text" },
];
const accent = [
  { n: "Indigo", hex: "#14233b", role: "masthead / map" },
  { n: "Cobalt", hex: "#1e5fa8", role: "links · landmarks" },
  { n: "Gold", hex: "#d6a53c", role: "CTA · featured" },
  { n: "Cinnabar", hex: "#c0533b", role: "eyebrows · markets" },
  { n: "Green", hex: "#4e7a52", role: "parks" },
  { n: "Claret", hex: "#8c3f5e", role: "food & cafés" },
];
const pins = [
  { c: "#1e5fa8", l: "Landmarks" },
  { c: "#c0533b", l: "Markets" },
  { c: "#c2922f", l: "Museums" },
  { c: "#4e7a52", l: "Parks" },
  { c: "#8c3f5e", l: "Food" },
];
const illos: IlloName[] = ["dome", "facade", "market", "terrace", "river"];
---

<Base title="Design System — Cuenca Expat Map">
  <Nav />

  <!-- Masthead -->
  <section class="relative overflow-hidden bg-[#0e1a2e] text-[#f4efe2]">
    <AndesBackdrop />
    <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(130% 110% at 12% 30%, rgba(14,26,46,.2), rgba(14,26,46,.85) 75%)"></div>
    <div class="relative mx-auto max-w-[1100px] px-6 py-16">
      <p class="eyebrow text-[11px] font-bold uppercase text-gold">Cuenca Expat Map</p>
      <h1 class="mt-3 font-display text-[2.6rem] font-semibold leading-[1.04] tracking-tight sm:text-[3.4rem]">Design System</h1>
      <p class="mt-4 max-w-[58ch] text-[16px] leading-relaxed text-[#9fb0c6]">An editorial system rooted in Cuenca — colonial blues and toquilla gold against warm marble paper, set in Newsreader and Hanken Grotesk. The reference for every page in the guide.</p>
      <div class="mt-6 flex flex-wrap gap-2 text-[12px]">
        <a href="#colors" class="rounded-full border border-white/25 px-3.5 py-1.5 text-[#cdd6e3] transition hover:border-gold hover:text-gold-soft">Colors</a>
        <a href="#type" class="rounded-full border border-white/25 px-3.5 py-1.5 text-[#cdd6e3] transition hover:border-gold hover:text-gold-soft">Type</a>
        <a href="#spacing" class="rounded-full border border-white/25 px-3.5 py-1.5 text-[#cdd6e3] transition hover:border-gold hover:text-gold-soft">Radii &amp; elevation</a>
        <a href="#components" class="rounded-full border border-white/25 px-3.5 py-1.5 text-[#cdd6e3] transition hover:border-gold hover:text-gold-soft">Components</a>
      </div>
    </div>
  </section>

  <main class="mx-auto max-w-[1100px] px-6">
    <!-- COLORS -->
    <section id="colors" class="scroll-mt-20 border-b border-line py-16">
      <p class="eyebrow text-[11px] font-bold uppercase text-cinnabar">Foundations</p>
      <h2 class="mt-2 font-display text-3xl font-semibold tracking-tight text-indigo">Color</h2>

      <h3 class="mt-9 text-[12px] font-bold uppercase tracking-wide text-slate">Surfaces &amp; ink</h3>
      <div class="mt-4 grid grid-cols-2 gap-4 sm:grid-cols-4">
        {neutral.map((s) => (
          <div class="overflow-hidden rounded-xl border border-line">
            <div class="h-20" style={`background:${s.hex}`}></div>
            <div class="bg-paper px-3 py-2.5"><p class="text-[13px] font-semibold text-ink">{s.n}</p><p class="font-mono text-[11px] uppercase text-slate">{s.hex}</p><p class="mt-0.5 text-[11px] text-slate">{s.role}</p></div>
          </div>
        ))}
      </div>

      <h3 class="mt-10 text-[12px] font-bold uppercase tracking-wide text-slate">Accents — drawn from the city &amp; flag</h3>
      <div class="mt-4 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-6">
        {accent.map((s) => (
          <div class="overflow-hidden rounded-xl border border-line">
            <div class="h-20" style={`background:${s.hex}`}></div>
            <div class="bg-paper px-3 py-2.5"><p class="text-[13px] font-semibold text-ink">{s.n}</p><p class="font-mono text-[11px] uppercase text-slate">{s.hex}</p><p class="mt-0.5 text-[11px] text-slate">{s.role}</p></div>
          </div>
        ))}
      </div>
    </section>

    <!-- TYPE -->
    <section id="type" class="scroll-mt-20 border-b border-line py-16">
      <p class="eyebrow text-[11px] font-bold uppercase text-cinnabar">Foundations</p>
      <h2 class="mt-2 font-display text-3xl font-semibold tracking-tight text-indigo">Typography</h2>

      <div class="mt-9 grid gap-6 sm:grid-cols-2">
        <div class="rounded-2xl border border-line bg-marble/50 p-6">
          <p class="text-[12px] font-bold uppercase tracking-wide text-slate">Display / Editorial</p>
          <p class="mt-2 font-display text-[3.2rem] font-semibold leading-none text-indigo">Newsreader</p>
          <p class="mt-3 font-display text-[1.3rem] italic text-slate">Aa Bb Cc — “the best morning in Cuenca”</p>
          <p class="mt-4 text-[13px] text-slate">Headlines, review titles, long-form body, pull quotes. Weights 400–600 + italic.</p>
        </div>
        <div class="rounded-2xl border border-line bg-marble/50 p-6">
          <p class="text-[12px] font-bold uppercase tracking-wide text-slate">Interface / Sans</p>
          <p class="mt-2 font-sans text-[3.2rem] font-bold leading-none text-indigo">Hanken</p>
          <p class="mt-3 font-sans text-[1.2rem] text-slate">Aa Bb Cc 0123456789</p>
          <p class="mt-4 text-[13px] text-slate">Nav, labels, eyebrows, buttons, captions, meta. Weights 400–800.</p>
        </div>
      </div>

      <div class="mt-8 space-y-5 rounded-2xl border border-line p-7">
        <div class="flex flex-wrap items-baseline gap-x-4"><span class="w-28 shrink-0 text-[11px] font-bold uppercase tracking-wide text-slate">Display / 3.4rem</span><span class="font-display text-[3.4rem] font-semibold leading-none tracking-tight text-indigo">A slow morning</span></div>
        <div class="flex flex-wrap items-baseline gap-x-4"><span class="w-28 shrink-0 text-[11px] font-bold uppercase tracking-wide text-slate">H2 / 1.85rem</span><span class="font-display text-[1.85rem] font-semibold text-indigo">The build-your-own breakfast</span></div>
        <div class="flex flex-wrap items-baseline gap-x-4"><span class="w-28 shrink-0 text-[11px] font-bold uppercase tracking-wide text-slate">Lede / 1.3rem</span><span class="font-display text-[1.3rem] italic text-slate">Bottomless coffee and a sunny terrace.</span></div>
        <div class="flex flex-wrap items-baseline gap-x-4"><span class="w-28 shrink-0 text-[11px] font-bold uppercase tracking-wide text-slate">Body / 1.22rem</span><span class="max-w-[46ch] font-display text-[1.22rem] leading-relaxed text-[#2c2a25]">Serif body copy keeps the long-form reviews feeling like a printed magazine — calm, readable, unhurried.</span></div>
        <div class="flex flex-wrap items-baseline gap-x-4"><span class="w-28 shrink-0 text-[11px] font-bold uppercase tracking-wide text-slate">UI / 0.875rem</span><span class="font-sans text-sm font-medium text-ink">Interface label · Hanken Grotesk</span></div>
        <div class="flex flex-wrap items-baseline gap-x-4"><span class="w-28 shrink-0 text-[11px] font-bold uppercase tracking-wide text-slate">Eyebrow</span><span class="eyebrow text-[11px] font-bold uppercase text-cinnabar">Food &amp; cafés · El Centro</span></div>
      </div>
    </section>

    <!-- SPACING -->
    <section id="spacing" class="scroll-mt-20 border-b border-line py-16">
      <p class="eyebrow text-[11px] font-bold uppercase text-cinnabar">Foundations</p>
      <h2 class="mt-2 font-display text-3xl font-semibold tracking-tight text-indigo">Radii &amp; elevation</h2>
      <div class="mt-9 grid gap-6 sm:grid-cols-3">
        <div class="rounded-2xl border border-line p-6">
          <p class="text-[12px] font-bold uppercase tracking-wide text-slate">Radii</p>
          <div class="mt-5 flex items-end gap-4">
            <div><div class="h-16 w-16 rounded-lg border border-line bg-marble"></div><p class="mt-2 text-center text-[11px] text-slate">lg · 8</p></div>
            <div><div class="h-16 w-16 rounded-xl border border-line bg-marble"></div><p class="mt-2 text-center text-[11px] text-slate">xl · 12</p></div>
            <div><div class="h-16 w-16 rounded-2xl border border-line bg-marble"></div><p class="mt-2 text-center text-[11px] text-slate">2xl · 16</p></div>
            <div><div class="h-16 w-16 rounded-full border border-line bg-marble"></div><p class="mt-2 text-center text-[11px] text-slate">full</p></div>
          </div>
        </div>
        <div class="rounded-2xl border border-line p-6">
          <p class="text-[12px] font-bold uppercase tracking-wide text-slate">Elevation</p>
          <div class="mt-5 flex items-center gap-5">
            <div class="h-16 w-20 rounded-xl bg-paper shadow-[0_1px_3px_rgba(20,35,59,.12)]"></div>
            <div class="h-16 w-20 rounded-xl bg-paper shadow-[0_24px_50px_-28px_rgba(20,35,59,.45)]"></div>
          </div>
          <p class="mt-4 text-[12px] text-slate">Hairline card → lifted hover. Shadows stay warm-navy, never gray.</p>
        </div>
        <div class="rounded-2xl border border-line p-6">
          <p class="text-[12px] font-bold uppercase tracking-wide text-slate">Hairline &amp; container</p>
          <div class="mt-5 space-y-3">
            <div class="h-px w-full bg-line"></div>
            <p class="text-[12px] text-slate">1px <code class="rounded bg-marble px-1.5 py-0.5">--color-line</code> divides every section.</p>
            <p class="text-[12px] text-slate">Content max-width <strong class="text-ink">1240px</strong>; reading measure <strong class="text-ink">680px</strong>.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- COMPONENTS -->
    <section id="components" class="scroll-mt-20 py-16">
      <p class="eyebrow text-[11px] font-bold uppercase text-cinnabar">Library</p>
      <h2 class="mt-2 font-display text-3xl font-semibold tracking-tight text-indigo">Components</h2>

      <h3 class="mt-9 text-[12px] font-bold uppercase tracking-wide text-slate">Buttons &amp; links</h3>
      <div class="mt-4 flex flex-wrap items-center gap-4 rounded-2xl border border-line bg-marble/40 p-7">
        <button class="rounded-lg bg-gold px-5 py-2.5 text-sm font-bold text-[#3a2a08] transition hover:bg-gold-soft">Get directions</button>
        <button class="rounded-full border border-indigo px-5 py-2.5 text-sm font-semibold text-indigo transition hover:bg-indigo hover:text-paper">All reviews →</button>
        <a class="text-sm font-semibold text-cobalt hover:underline" href="#components">Read review →</a>
      </div>

      <h3 class="mt-10 text-[12px] font-bold uppercase tracking-wide text-slate">Map pins &amp; category system</h3>
      <div class="mt-4 flex flex-wrap items-center gap-7 rounded-2xl border border-line bg-indigo p-7">
        {pins.map((p) => (
          <div class="flex flex-col items-center gap-2">
            <span class="grid h-[22px] w-[22px] place-items-center rounded-full" style={`background:${p.c};border:2.5px solid #f4efe2;box-shadow:0 2px 7px rgba(0,0,0,.6)`}></span>
            <span class="text-[11px] text-[#9fb0c6]">{p.l}</span>
          </div>
        ))}
        <div class="flex flex-col items-center gap-2">
          <span class="grid h-8 w-8 place-items-center rounded-full text-[13px] text-white" style="background:#8c3f5e;border:2.5px solid #d6a53c;box-shadow:0 0 0 3px rgba(214,165,60,.4),0 3px 9px rgba(0,0,0,.6)">★</span>
          <span class="text-[11px] font-semibold text-gold-soft">Reviewed</span>
        </div>
      </div>

      <h3 class="mt-10 text-[12px] font-bold uppercase tracking-wide text-slate">Filter chips</h3>
      <div class="mt-4 flex flex-wrap items-center gap-2 rounded-2xl border border-line bg-indigo p-7">
        <span class="rounded-full bg-gold px-3.5 py-1.5 text-[13px] font-semibold text-[#3a2a08]">All</span>
        <span class="rounded-full bg-paper px-3.5 py-1.5 text-[13px] font-semibold text-indigo"><span class="mr-1.5 inline-block h-2 w-2 rounded-full align-middle" style="background:#8c3f5e"></span>Food &amp; cafés</span>
        <span class="rounded-full border border-white/20 px-3.5 py-1.5 text-[13px] text-[#9fb0c6]"><span class="mr-1.5 inline-block h-2 w-2 rounded-full align-middle" style="background:#1e5fa8"></span>Landmarks &amp; plazas</span>
        <span class="rounded-full border border-white/20 px-3.5 py-1.5 text-[13px] text-[#9fb0c6]"><span class="mr-1.5 inline-block h-2 w-2 rounded-full align-middle" style="background:#4e7a52"></span>Parks &amp; views</span>
      </div>

      <h3 class="mt-10 text-[12px] font-bold uppercase tracking-wide text-slate">Featured badge → review link</h3>
      <div class="mt-4 grid gap-6 sm:grid-cols-2">
        <div class="rounded-2xl border border-line bg-indigo p-7">
          <p class="text-[12px] text-[#9fb0c6]">The gold seal marks a reviewed venue. On the map &amp; listing it's a live link to the review.</p>
          <div class="mt-5 flex items-center gap-6">
            <span class="block h-20 w-20">
              <svg viewBox="0 0 100 100" class="h-full w-full">
                <defs><path id="ds-ring" d="M50 50 m-41 0 a41 41 0 1 1 82 0 a41 41 0 1 1 -82 0"></path></defs>
                <circle cx="50" cy="50" r="48" fill="#14233b"></circle>
                <circle cx="50" cy="50" r="46" fill="none" stroke="#d6a53c" stroke-width="1.3"></circle>
                <circle cx="50" cy="50" r="33" fill="#d6a53c"></circle>
                <text style="font-family:Hanken Grotesk;font-size:7px;font-weight:700;letter-spacing:1.3px;fill:#d6a53c"><textPath href="#ds-ring" startOffset="0%">REVIEWED · CUENCA · REVIEWED · CUENCA · </textPath></text>
                <text x="50" y="60" text-anchor="middle" style="font-size:22px;fill:#14233b">★</text>
              </svg>
            </span>
            <a href="/reviews/review-cafe-san-sebas" class="flex items-center justify-between gap-3 rounded-xl border border-gold/40 bg-gold/10 px-4 py-3 text-sm font-semibold text-gold-soft transition hover:bg-gold/20">★ Read our full review <span>→</span></a>
          </div>
        </div>
        <div class="rounded-2xl border border-line bg-paper p-7">
          <p class="text-[12px] text-slate">Rating pills &amp; status badges</p>
          <div class="mt-5 flex flex-wrap items-center gap-3">
            <span class="inline-flex items-center gap-1.5 rounded-full border border-gold/50 bg-gold/10 px-3 py-1 text-[13px] font-semibold text-[#9a7320]">★ 4.6 · Local favorite</span>
            <span class="inline-flex items-center gap-1 rounded-full bg-indigo px-2.5 py-1 text-[11px] font-bold text-gold-soft">★ 4.5</span>
            <span class="rounded-full bg-gold px-3 py-1 text-[11px] font-bold uppercase tracking-wide text-[#3a2a08]">★ Editors' pick</span>
          </div>
        </div>
      </div>

      <h3 class="mt-10 text-[12px] font-bold uppercase tracking-wide text-slate">Illustrated placeholders</h3>
      <p class="mt-1 text-[13px] text-slate">Flat, geometric stand-ins for real photography — swap each for a venue-supplied image at launch.</p>
      <div class="mt-4 grid grid-cols-2 gap-4 sm:grid-cols-5">
        {illos.map((k) => (
          <div>
            <div class="aspect-[4/3] overflow-hidden rounded-xl border border-line"><Illustration name={k} /></div>
            <p class="mt-1.5 text-center text-[11px] text-slate">{k}</p>
          </div>
        ))}
      </div>
    </section>
  </main>

  <Footer note="Design system · v1" />
</Base>
