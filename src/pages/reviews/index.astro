---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import AndesBackdrop from "../../components/AndesBackdrop.astro";
import ReviewCard from "../../components/ReviewCard.astro";
import Illustration from "../../components/Illustration.astro";
import { getReviews } from "../../lib/content";
import { CAT_KEY_BY_LABEL } from "../../i18n/ui";

const reviews = await getReviews();
const [lead, ...rest] = reviews;
const leadCatKey = CAT_KEY_BY_LABEL[lead.category] ?? "";
---

<Base title="Reviews — Cuenca Expat Map" description="Independent, long-form reviews of the restaurants, cafés and markets worth your time in Cuenca, Ecuador.">
  <Nav active="reviews" />

  <!-- DARK HEADER -->
  <section class="relative overflow-hidden bg-[#0e1a2e] text-[#f4efe2]">
    <AndesBackdrop />
    <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(130% 120% at 12% 30%, rgba(14,26,46,.2), rgba(14,26,46,.85) 75%)"></div>
    <div class="relative mx-auto max-w-[1240px] px-6 pt-16 pb-14">
      <p class="eyebrow text-[11px] font-bold uppercase text-gold" data-i18n="rev_eyebrow">Independent &amp; unsponsored</p>
      <h1 class="mt-3 max-w-[18ch] font-display text-[2.8rem] font-semibold leading-[1.02] tracking-tight sm:text-[3.6rem]" data-i18n="rev_title">Reviews</h1>
      <p class="mt-4 max-w-[56ch] text-[16px] leading-relaxed text-[#9fb0c6]" data-i18n="rev_dek">We write up the places we actually go back to — in full, in our own words, with no one paying for the privilege. Start here.</p>
    </div>
  </section>

  <!-- FEATURED REVIEW -->
  <section class="mx-auto max-w-[1240px] px-6 pt-12">
    <a
      href={lead.published ? `/reviews/${lead.slug}` : undefined}
      class="group grid overflow-hidden rounded-2xl border border-line bg-marble/50 transition hover:shadow-[0_30px_70px_-38px_rgba(20,35,59,.5)] md:grid-cols-2"
    >
      <div class="relative aspect-[16/10] overflow-hidden md:aspect-auto">
        <Illustration name={lead.cardIllo} />
        <span class="absolute left-4 top-4 rounded-full bg-gold px-3 py-1 text-[11px] font-bold uppercase tracking-wide text-[#3a2a08]" data-i18n="editors_pick">★ Editors' pick</span>
      </div>
      <div class="flex flex-col justify-center p-8 sm:p-10">
        <span class="eyebrow text-[11px] font-bold uppercase text-cinnabar"><span data-i18n={leadCatKey}>{lead.category}</span> · ★ {lead.rating}</span>
        <h3 class="mt-2 font-display text-[2rem] font-semibold leading-tight text-indigo sm:text-[2.4rem]">{lead.name}</h3>
        <p class="mt-3 text-[15.5px] leading-relaxed text-slate" data-en={lead.dek} data-es={lead.dekEs ?? lead.dek}>{lead.dek}</p>
        <span class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-cobalt"><span data-i18n="read_full">Read the full review</span> <span class="transition group-hover:translate-x-0.5">→</span></span>
      </div>
    </a>
  </section>

  <!-- GRID -->
  <section class="mx-auto max-w-[1240px] px-6 pb-20 pt-10">
    <div class="flex items-center gap-3">
      <h2 class="font-display text-xl font-semibold text-indigo" data-i18n="rev_latest">Latest reviews</h2>
      <span class="h-px flex-1 bg-line"></span>
    </div>
    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {rest.map((review) => <ReviewCard review={review} size="sm" />)}
    </div>
  </section>

  <Footer />
</Base>
