---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import AndesBackdrop from "../components/AndesBackdrop.astro";
import { getInventory } from "../lib/content";

const inventory = await getInventory();

// Precompute display values here — comparison operators (<, >, <=) confuse the
// Astro template parser when used inside JSX expression blocks.
const slots = inventory.map((c) => ({
  ...c,
  pct: c.cap > 0 ? Math.min(100, Math.round((c.used / c.cap) * 100)) : 100,
  full: c.remaining <= 0,
  remainEn: `${c.remaining} of ${c.cap} slots remaining`,
  remainEs: `${c.remaining} de ${c.cap} cupos disponibles`,
}));

const inputCls =
  "mt-1.5 w-full rounded-lg border border-line bg-marble/40 px-3.5 py-2.5 text-sm text-ink outline-none transition focus:border-cobalt focus:bg-paper";
const labelCls = "text-[12px] font-bold uppercase tracking-wide text-slate";
---

<Base
  title="List your business — Cuenca Expat Map"
  description="Get a featured listing on the Cuenca Expat Map. See what's open by category and join the waitlist."
>
  <Nav active="list" />

  <!-- DARK HEADER -->
  <section class="relative overflow-hidden bg-[#0e1a2e] text-[#f4efe2]">
    <AndesBackdrop />
    <div class="pointer-events-none absolute inset-0" style="background:radial-gradient(130% 120% at 12% 30%, rgba(14,26,46,.2), rgba(14,26,46,.85) 75%)"></div>
    <div class="relative mx-auto max-w-[1240px] px-6 pt-16 pb-14">
      <p class="eyebrow text-[11px] font-bold uppercase text-gold" data-i18n="list_eyebrow">For business owners</p>
      <h1 class="mt-3 max-w-[18ch] font-display text-[2.8rem] font-semibold leading-[1.02] tracking-tight sm:text-[3.4rem]" data-i18n="list_title">List your business in Cuenca</h1>
      <p class="mt-4 max-w-[58ch] text-[16px] leading-relaxed text-[#9fb0c6]" data-i18n="list_dek">A pin on the map is always free. Featured listings — photos, hours, live specials, and a full honest review — are limited per category. Here's what's open right now.</p>
    </div>
  </section>

  <!-- AVAILABILITY -->
  <section class="mx-auto max-w-[1240px] px-6 pt-14">
    <div class="flex items-center gap-3">
      <h2 class="font-display text-xl font-semibold text-indigo" data-i18n="list_avail">Availability by category</h2>
      <span class="h-px flex-1 bg-line"></span>
    </div>

    <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {slots.map((c) => (
        <div class="rounded-2xl border border-line bg-paper p-6">
          <div class="flex items-center gap-2.5">
            <span class="h-3 w-3 rounded-full" style={`background:${c.color}`}></span>
            <span class="eyebrow text-[10px] font-bold uppercase text-cinnabar" data-i18n={`cat_${c.key}`}>{c.label}</span>
          </div>
          <p class="mt-3 font-display text-[2rem] font-semibold leading-none text-indigo">
            {c.used}<span class="text-[1rem] font-medium text-slate"> / {c.cap}</span>
          </p>
          <p class="mt-1 text-[13px] text-slate">
            {c.full
              ? <span data-i18n="list_full">Full — join the waitlist</span>
              : <span data-en={c.remainEn} data-es={c.remainEs}>{c.remainEn}</span>}
          </p>
          <div class="mt-4 h-1.5 overflow-hidden rounded-full bg-marble">
            <div class="h-full rounded-full" style={`width:${c.pct}%;background:${c.full ? "#c0533b" : c.color}`}></div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- WAITLIST -->
  <section class="mx-auto max-w-[1240px] px-6 py-16 sm:py-20">
    <div class="grid gap-12 lg:grid-cols-[1fr_1.05fr]">
      <div>
        <p class="eyebrow text-[11px] font-bold uppercase text-cinnabar" data-i18n="biz_eyebrow">For business owners</p>
        <h2 class="mt-2 font-display text-3xl font-semibold leading-tight tracking-tight text-indigo sm:text-[2.4rem]" data-i18n="wl_title">Join the waitlist</h2>
        <p class="mt-4 max-w-[46ch] text-[15.5px] leading-relaxed text-slate" data-i18n="wl_dek">Tell us about your place and which category you're in. We'll reach out as a featured slot opens up.</p>
      </div>

      <form id="waitlist-form" class="rounded-2xl border border-line bg-paper p-7 shadow-[0_24px_50px_-30px_rgba(20,35,59,.35)]">
        <div class="grid gap-4">
          <label class="block">
            <span class={labelCls} data-i18n="form_name">Your name</span>
            <input type="text" name="name" required class={inputCls} />
          </label>
          <label class="block">
            <span class={labelCls} data-i18n="form_business">Business name</span>
            <input type="text" name="business" required class={inputCls} />
          </label>
          <label class="block">
            <span class={labelCls} data-i18n="form_email">Email</span>
            <input type="email" name="email" required class={inputCls} />
          </label>
          <label class="block">
            <span class={labelCls} data-i18n="wl_cat">Category</span>
            <select name="category" required class={inputCls}>
              {slots.map((c) => (
                <option value={c.id}>{c.label}{c.full ? " (waitlist)" : ""}</option>
              ))}
            </select>
          </label>
          <label class="block">
            <span class={labelCls} data-i18n="form_message">Anything we should know? (optional)</span>
            <textarea name="message" rows="3" class={`${inputCls} resize-none`}></textarea>
          </label>
          <button type="submit" class="mt-1 rounded-lg bg-gold px-5 py-3 text-sm font-bold text-[#3a2a08] transition hover:bg-gold-soft" data-i18n="wl_send">Join the waitlist</button>
        </div>
        <p id="wl-thanks" class="mt-4 hidden text-sm font-semibold text-green" data-i18n="wl_thanks">You're on the list — we'll be in touch soon.</p>
        <p id="wl-error" class="mt-4 hidden text-sm font-semibold text-cinnabar" data-i18n="form_error">Something went wrong — please try again.</p>
      </form>
    </div>
  </section>

  <Footer />
</Base>

<script>
  import { createLead } from "../lib/leads";

  const form = document.getElementById("waitlist-form") as HTMLFormElement | null;
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const businessName = String(fd.get("business") || "").trim();
    const note = String(fd.get("message") || "").trim();

    const btn = form.querySelector("button[type=submit]") as HTMLButtonElement;
    btn.disabled = true;

    const ok = await createLead({
      name: String(fd.get("name") || "").trim(),
      email: String(fd.get("email") || "").trim(),
      category: String(fd.get("category") || "") || undefined,
      message: [businessName && `Business: ${businessName}`, note].filter(Boolean).join("\n"),
      source: "waitlist",
    });

    if (ok) {
      form.querySelectorAll("input,textarea,select,button").forEach((el) => ((el as HTMLInputElement).disabled = true));
      document.getElementById("wl-thanks")?.classList.remove("hidden");
    } else {
      btn.disabled = false;
      document.getElementById("wl-error")?.classList.remove("hidden");
    }
  });
</script>
